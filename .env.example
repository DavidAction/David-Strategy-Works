# David Strategy Works local environment
PORT=8765

# AI pipeline
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional OCR command adapters.
# If installed locally, server.py can use these commands for OCR fallback.
TESSERACT_CMD=tesseract
PDFTOPPM_CMD=pdftoppm
OCR_LANG=kor+eng

# Optional local workspace protection.
# Set a password before sharing the app on a local network.
DSW_WORKSPACE_PASSWORD=

# Production-safe defaults.
# Blocks exports when high-risk evidence or AI-transfer gaps remain.
DSW_BLOCK_UNSAFE_EXPORT=true
DSW_EXPORT_RETENTION_DAYS=30
